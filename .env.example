# Admin secret for creating API keys via POST /api/keys
ADMIN_SECRET=change-me

# Port for the proxy server
PORT=3000

# SQLite database path
DB_PATH=./data/guard.db

# Optional: Default webhook URL for alerts
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...

# Optional: Use LLM-as-judge for quality scoring (sampled 10% of calls)
# Set to your Anthropic API key to enable deep quality evaluation
# JUDGE_API_KEY=sk-ant-...
# JUDGE_MODEL=claude-haiku-4-5-20251001
# JUDGE_SAMPLE_RATE=0.1



OPENAI_API_KEY=sk-...
# Groq API Key (free tier) — https://console.groq.com
GROQ_API_KEY=gsk_...
